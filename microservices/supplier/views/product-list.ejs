<!DOCTYPE html>
<html>
<head>
  <title>Products - Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2>Products Management</h2>
      <a href="/admin/products/add" class="btn btn-primary">+ Add Product</a>
    </div>
    <% if (products.length === 0) { %>
      <p class="text-muted">No products yet. <a href="/admin/products/add">Add your first product</a>.</p>
    <% } else { %>
      <table class="table table-striped align-middle">
        <thead><tr><th>Image</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% products.forEach(function(p) { %>
            <tr>
              <td>
                <% if (p.image_url) { %>
                  <img src="<%= p.image_url %>" alt="<%= p.name %>" style="width:60px; height:60px; object-fit:cover; border-radius:6px;">
                <% } else { %>
                  <div style="width:60px; height:60px; background:#eee; border-radius:6px; display:flex; align-items:center; justify-content:center; color:#999; font-size:24px;">?</div>
                <% } %>
              </td>
              <td><strong><%= p.name %></strong><br><small class="text-muted"><%= p.supplier_name %></small></td>
              <td><%= p.category || '-' %></td>
              <td>$<%= parseFloat(p.price).toFixed(2) %></td>
              <td><%= p.stock %></td>
              <td><span class="badge bg-<%= p.status === 'active' ? 'success' : 'secondary' %>"><%= p.status %></span></td>
              <td>
                <a href="/admin/products/edit/<%= p.id %>" class="btn btn-sm btn-outline-primary">Edit</a>
                <form method="POST" action="/admin/products/delete/<%= p.id %>" style="display:inline" onsubmit="return confirm('Delete this product?')">
                  <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
