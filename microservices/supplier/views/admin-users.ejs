<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Management - Admin</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f5f5; }
    .card { border:0; border-radius:12px; }
    .table th { font-weight:600; font-size:.85rem; text-transform:uppercase; letter-spacing:.5px; color:#555; border-bottom:2px solid #dee2e6; }
    .table td { vertical-align:middle; }
    .stat-card { transition:transform .2s; }
    .stat-card:hover { transform:translateY(-3px); }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/manage" class="text-decoration-none" style="color:#1a1a2e">Admin Dashboard</a></li>
        <li class="breadcrumb-item active">User Management</li>
      </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h3 class="fw-bold mb-1">User Management</h3>
        <p class="text-muted mb-0">Approve, reject, or remove user accounts</p>
      </div>
    </div>

    <!-- Stats -->
    <% var totalU=users.length, pendingU=0, suppliers=0, buyers=0;
       users.forEach(function(u){ if(u.status==='pending') pendingU++; if(u.role==='supplier') suppliers++; if(u.role==='shop') buyers++; }); %>
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3"><div class="card shadow-sm stat-card p-3 text-center"><div class="fs-3 fw-bold text-primary"><%= totalU %></div><small class="text-muted">Total Users</small></div></div>
      <div class="col-6 col-md-3"><div class="card shadow-sm stat-card p-3 text-center"><div class="fs-3 fw-bold text-warning"><%= pendingU %></div><small class="text-muted">Pending Approval</small></div></div>
      <div class="col-6 col-md-3"><div class="card shadow-sm stat-card p-3 text-center"><div class="fs-3 fw-bold text-success"><%= suppliers %></div><small class="text-muted">Suppliers</small></div></div>
      <div class="col-6 col-md-3"><div class="card shadow-sm stat-card p-3 text-center"><div class="fs-3 fw-bold text-info"><%= buyers %></div><small class="text-muted">Buyers</small></div></div>
    </div>

    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="bg-light">
            <tr><th>ID</th><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Joined</th><th class="text-end">Actions</th></tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
            <tr>
              <td class="fw-semibold">#<%= u.id %></td>
              <td><%= u.full_name %></td>
              <td><%= u.email %></td>
              <td><span class="badge bg-<%= u.role === 'admin' ? 'danger' : u.role === 'supplier' ? 'primary' : 'success' %>"><%= u.role %></span></td>
              <td>
                <% if (u.status === 'approved') { %><span class="badge bg-success">Approved</span>
                <% } else if (u.status === 'pending') { %><span class="badge bg-warning">Pending</span>
                <% } else { %><span class="badge bg-danger">Rejected</span><% } %>
              </td>
              <td><%= new Date(u.created_at).toLocaleDateString() %></td>
              <td class="text-end">
                <% if (u.status === 'pending') { %>
                  <form action="/admin/manage/users/<%= u.id %>/approve" method="POST" class="d-inline">
                    <button class="btn btn-sm btn-success">Approve</button>
                  </form>
                  <form action="/admin/manage/users/<%= u.id %>/reject" method="POST" class="d-inline">
                    <button class="btn btn-sm btn-outline-warning">Reject</button>
                  </form>
                <% } %>
                <% if (u.role !== 'admin') { %>
                  <form action="/admin/manage/users/<%= u.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete user <%= u.full_name %>? This cannot be undone.')">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
