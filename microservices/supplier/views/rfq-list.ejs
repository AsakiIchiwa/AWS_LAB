<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RFQ Requests - Supplier Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f7f5; }
    .card { border:0; border-radius:12px; }
    .stat-card { transition:transform .2s; }
    .stat-card:hover { transform:translateY(-3px); }
    .table th { font-weight:600; font-size:.85rem; text-transform:uppercase; letter-spacing:.5px; color:#555; border-bottom:2px solid #dee2e6; }
    .table td { vertical-align:middle; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <div class="mb-4">
      <h3 class="fw-bold mb-1">Incoming RFQ Requests</h3>
      <p class="text-muted mb-0">Review and respond to buyer quotation requests</p>
    </div>

    <!-- Stats -->
    <% var pending=0, quoted=0, accepted=0;
       rfqs.forEach(function(r){ if(r.status==='pending') pending++; else if(r.status==='quoted') quoted++; else if(r.status==='accepted') accepted++; }); %>
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card p-3 text-center">
          <div class="fs-3 fw-bold text-success"><%= rfqs.length %></div>
          <small class="text-muted">Total RFQs</small>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card p-3 text-center">
          <div class="fs-3 fw-bold text-warning"><%= pending %></div>
          <small class="text-muted">Needs Quote</small>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card p-3 text-center">
          <div class="fs-3 fw-bold text-info"><%= quoted %></div>
          <small class="text-muted">Quoted</small>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card p-3 text-center">
          <div class="fs-3 fw-bold text-primary"><%= accepted %></div>
          <small class="text-muted">Accepted</small>
        </div>
      </div>
    </div>

    <% if (rfqs.length === 0) { %>
      <div class="card shadow-sm p-5 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#aaa" class="mx-auto mb-3" viewBox="0 0 16 16"><path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2z"/><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/></svg>
        <h5 class="text-muted">No RFQ requests yet</h5>
        <p class="text-muted">When buyers request quotes on your products, they will appear here.</p>
      </div>
    <% } else { %>
      <div class="card shadow-sm">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="bg-light">
              <tr><th>#</th><th>Product</th><th>Buyer</th><th>Quantity</th><th>Status</th><th>Date</th><th class="text-end">Action</th></tr>
            </thead>
            <tbody>
              <% rfqs.forEach(function(r) { %>
              <tr>
                <td class="fw-semibold">#<%= r.id %></td>
                <td><%= r.product_name %></td>
                <td><%= r.shop_name %></td>
                <td><%= r.quantity %> units</td>
                <td>
                  <% if (r.status === 'pending') { %><span class="badge bg-warning">Needs Quote</span>
                  <% } else if (r.status === 'quoted') { %><span class="badge bg-info">Quoted</span>
                  <% } else if (r.status === 'accepted') { %><span class="badge bg-success">Accepted</span>
                  <% } else if (r.status === 'rejected') { %><span class="badge bg-danger">Rejected</span>
                  <% } else { %><span class="badge bg-secondary"><%= r.status %></span><% } %>
                </td>
                <td><%= new Date(r.created_at).toLocaleDateString() %></td>
                <td class="text-end">
                  <a href="/admin/rfqs/<%= r.id %>" class="btn btn-sm <%= r.status === 'pending' ? 'btn-success' : 'btn-outline-primary' %>">
                    <%= r.status === 'pending' ? 'Submit Quote' : (r.status === 'quoted' ? 'Update Quote' : 'View Details') %>
                  </a>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
