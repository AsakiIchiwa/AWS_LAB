<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>RFQ #<%= rfq.id %> - Supplier Portal</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <style>
    body { background:#f5f7f5; }
    .card { border:0; border-radius:12px; }
    .status-banner { border-radius:12px; padding:1rem 1.5rem; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>
  <div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/admin/rfqs" class="text-success text-decoration-none">RFQ Requests</a></li>
        <li class="breadcrumb-item active">RFQ #<%= rfq.id %></li>
      </ol>
    </nav>

    <% if (rfq.status === 'pending') { %>
      <div class="status-banner bg-warning bg-opacity-25 border border-warning mb-4">
        <strong>Action required:</strong> Submit a quote or reject this RFQ.
      </div>
    <% } else if (rfq.status === 'quoted') { %>
      <div class="status-banner bg-info bg-opacity-25 border border-info mb-4">
        <strong>Quote sent:</strong> You can update it while buyer has not made a decision.
      </div>
    <% } else if (rfq.status === 'accepted') { %>
      <div class="status-banner bg-success bg-opacity-25 border border-success mb-4">
        <strong>Accepted:</strong> Buyer accepted your quote.
      </div>
    <% } else if (rfq.status === 'rejected') { %>
      <div class="status-banner bg-danger bg-opacity-25 border border-danger mb-4">
        <strong>Closed:</strong> This RFQ is rejected.
      </div>
    <% } %>

    <div class="row g-4">
      <div class="col-lg-6">
        <div class="card shadow-sm p-4">
          <h5 class="fw-bold mb-3">Request Details</h5>
          <table class="table table-borderless mb-0">
            <tr><td class="text-muted" style="width:40%">Buyer</td><td class="fw-semibold"><%= rfq.shop_name %></td></tr>
            <tr><td class="text-muted">Product</td><td class="fw-semibold"><%= rfq.product_name %></td></tr>
            <tr><td class="text-muted">List Price</td><td>$<%= parseFloat(rfq.list_price).toFixed(2) %></td></tr>
            <tr><td class="text-muted">Requested Qty</td><td><%= rfq.quantity %> units</td></tr>
            <% if (rfq.note) { %><tr><td class="text-muted">Buyer Note</td><td><%= rfq.note %></td></tr><% } %>
            <tr><td class="text-muted">Submitted</td><td><%= new Date(rfq.created_at).toLocaleDateString() %></td></tr>
          </table>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card shadow-sm p-4">
          <h5 class="fw-bold mb-3"><%= rfq.quote_id ? 'Your Quote' : 'Submit Quote' %></h5>

          <% if (rfq.quote_id) { %>
            <div class="row g-2 mb-3">
              <div class="col-4 text-center p-2 bg-light rounded">
                <div class="fw-bold text-success">$<%= parseFloat(rfq.unit_price).toFixed(2) %></div>
                <small class="text-muted">Unit Price</small>
              </div>
              <div class="col-4 text-center p-2 bg-light rounded">
                <div class="fw-bold"><%= rfq.moq %></div>
                <small class="text-muted">MOQ</small>
              </div>
              <div class="col-4 text-center p-2 bg-light rounded">
                <div class="fw-bold"><%= rfq.delivery_days %></div>
                <small class="text-muted">Days</small>
              </div>
            </div>
            <% if (rfq.quote_note) { %>
              <p class="small text-muted mb-3"><strong>Note:</strong> <%= rfq.quote_note %></p>
            <% } %>
            <div class="mb-3">
              <strong>Status: </strong>
              <% if (rfq.quote_status === 'pending') { %><span class="badge bg-warning">Pending</span>
              <% } else if (rfq.quote_status === 'accepted') { %><span class="badge bg-success">Accepted</span>
              <% } else { %><span class="badge bg-danger">Rejected</span><% } %>
            </div>
          <% } %>

          <% if (!rfq.quote_id || (rfq.status === 'quoted' && rfq.quote_status === 'pending')) { %>
            <form action="/admin/rfqs/<%= rfq.id %>/quote" method="POST" class="mb-2">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Unit Price ($)</label>
                  <input type="number" name="unit_price" class="form-control" step="0.01" min="0.01" value="<%= rfq.quote_id ? rfq.unit_price : '' %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">MOQ</label>
                  <input type="number" name="moq" class="form-control" min="1" value="<%= rfq.quote_id ? rfq.moq : 1 %>">
                </div>
              </div>
              <div class="mt-3">
                <label class="form-label">Delivery Days</label>
                <input type="number" name="delivery_days" class="form-control" min="1" value="<%= rfq.quote_id ? rfq.delivery_days : 7 %>">
              </div>
              <div class="mt-3">
                <label class="form-label">Note</label>
                <textarea name="note" class="form-control" rows="2" maxlength="500"><%= rfq.quote_id && rfq.quote_note ? rfq.quote_note : '' %></textarea>
              </div>
              <button type="submit" class="btn btn-success w-100 mt-3"><%= rfq.quote_id ? 'Update Quote' : 'Submit Quote' %></button>
            </form>
          <% } %>

          <% if (rfq.status === 'pending' || (rfq.status === 'quoted' && rfq.quote_status === 'pending')) { %>
            <form action="/admin/rfqs/<%= rfq.id %>/reject" method="POST" onsubmit="return confirm('Reject this RFQ?');">
              <button type="submit" class="btn btn-outline-danger w-100">Reject RFQ</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
