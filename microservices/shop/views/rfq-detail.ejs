<!DOCTYPE html>
<html class="h-100">
<head>
  <title>RFQ #<%= rfq.id %> - B2B Marketplace</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="d-flex flex-column h-100 bg-light">
  <%- include('partials/nav') %>
  <div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb" class="mb-3">
      <ol class="breadcrumb small">
        <li class="breadcrumb-item"><a href="/rfqs" class="text-decoration-none">My RFQs</a></li>
        <li class="breadcrumb-item active">RFQ #<%= rfq.id %></li>
      </ol>
    </nav>

    <div class="alert py-2 mb-4
      <% if (rfq.status === 'pending') { %> alert-warning
      <% } else if (rfq.status === 'quoted') { %> alert-info
      <% } else if (rfq.status === 'accepted') { %> alert-success
      <% } else if (rfq.status === 'rejected') { %> alert-danger
      <% } else { %> alert-secondary <% } %>
    ">
      <div class="d-flex justify-content-between align-items-center">
        <span class="fw-semibold">
          <% if (rfq.status === 'pending') { %>Waiting for supplier response
          <% } else if (rfq.status === 'quoted') { %>Quote received. Review and decide.
          <% } else if (rfq.status === 'accepted') { %>Quote accepted. Order was created.
          <% } else if (rfq.status === 'rejected') { %>This RFQ has been rejected.
          <% } else { %>RFQ Status: <%= rfq.status %><% } %>
        </span>
        <span class="badge bg-white text-dark">RFQ #<%= rfq.id %></span>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
          <div class="card-header bg-white border-bottom-0 pt-4 px-4">
            <h5 class="fw-bold mb-0">Request Details</h5>
          </div>
          <div class="card-body px-4 pb-4">
            <div class="mb-3">
              <div class="small text-muted">Product</div>
              <div class="fw-semibold"><%= rfq.product_name %></div>
            </div>
            <div class="row g-3 mb-3">
              <div class="col-6">
                <div class="small text-muted">List Price</div>
                <div class="fw-semibold text-success">$<%= parseFloat(rfq.list_price).toFixed(2) %></div>
              </div>
              <div class="col-6">
                <div class="small text-muted">Requested Qty</div>
                <div class="fw-semibold"><%= rfq.quantity %> units</div>
              </div>
            </div>
            <div class="mb-3">
              <div class="small text-muted">Supplier</div>
              <div class="fw-semibold"><%= rfq.supplier_name %></div>
            </div>
            <% if (rfq.note) { %>
            <div class="mb-3">
              <div class="small text-muted">Your Note</div>
              <div class="bg-light rounded p-2 small"><%= rfq.note %></div>
            </div>
            <% } %>
            <div>
              <div class="small text-muted">Submitted</div>
              <div class="small"><%= new Date(rfq.created_at).toLocaleDateString() %></div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <% if (rfq.quote_id) { %>
        <div class="card border-0 shadow-sm h-100" style="border-radius:12px; border-left: 4px solid #0dcaf0 !important;">
          <div class="card-header bg-white border-bottom-0 pt-4 px-4">
            <h5 class="fw-bold mb-0">Supplier Quote</h5>
          </div>
          <div class="card-body px-4 pb-4">
            <div class="row g-3 mb-3">
              <div class="col-6">
                <div class="small text-muted">Unit Price</div>
                <div class="fs-5 fw-bold text-success">$<%= parseFloat(rfq.quoted_price).toFixed(2) %></div>
              </div>
              <div class="col-6">
                <div class="small text-muted">Estimated Total</div>
                <div class="fs-5 fw-bold">$<%= (parseFloat(rfq.quoted_price) * rfq.quantity).toFixed(2) %></div>
              </div>
            </div>
            <div class="row g-3 mb-3">
              <div class="col-6">
                <div class="small text-muted">MOQ</div>
                <div class="fw-semibold"><%= rfq.moq %> units</div>
              </div>
              <div class="col-6">
                <div class="small text-muted">Delivery</div>
                <div class="fw-semibold"><%= rfq.delivery_days %> days</div>
              </div>
            </div>
            <% if (rfq.quote_note) { %>
            <div class="mb-3">
              <div class="small text-muted">Supplier Note</div>
              <div class="bg-light rounded p-2 small"><%= rfq.quote_note %></div>
            </div>
            <% } %>
            <div class="mb-3">
              <div class="small text-muted">Quote Status</div>
              <% if (rfq.quote_status === 'pending') { %><span class="badge bg-warning bg-opacity-10 text-warning">Awaiting Decision</span>
              <% } else if (rfq.quote_status === 'accepted') { %><span class="badge bg-success bg-opacity-10 text-success">Accepted</span>
              <% } else { %><span class="badge bg-danger bg-opacity-10 text-danger">Rejected</span><% } %>
            </div>

            <% if (rfq.quote_status === 'pending' && rfq.status === 'quoted') { %>
            <hr>
            <div class="d-flex gap-2">
              <form action="/rfqs/<%= rfq.id %>/accept/<%= rfq.quote_id %>" method="POST" class="flex-fill">
                <button class="btn btn-success w-100">Accept and Create Order</button>
              </form>
              <form action="/rfqs/<%= rfq.id %>/reject/<%= rfq.quote_id %>" method="POST">
                <button class="btn btn-outline-danger px-4">Reject</button>
              </form>
            </div>
            <% } %>
          </div>
        </div>
        <% } else { %>
        <div class="card border-0 shadow-sm h-100" style="border-radius:12px;">
          <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-5">
            <div class="spinner-border text-warning mb-3" role="status" style="width:3rem;height:3rem;">
              <span class="visually-hidden">Loading...</span>
            </div>
            <h5 class="fw-bold">Awaiting Supplier Response</h5>
            <p class="text-muted small">The supplier has not submitted a quote yet.</p>
          </div>
        </div>
        <% } %>
      </div>
    </div>

    <div class="mt-4">
      <a href="/rfqs" class="btn btn-outline-secondary">Back to My RFQs</a>
    </div>
  </div>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
